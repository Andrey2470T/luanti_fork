{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 12
  },
  "configurePresets": [
    {
      "name": "Debug",
      "displayName": "Debug",
      "description": "Debug preset with debug symbols and no optimizations",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "Release",
      "displayName": "Release",
      "description": "Release preset with optimizations and no debug symbols",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "RelWithDebInfo",
      "displayName": "RelWithDebInfo",
      "description": "Release with debug symbols",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "MinSizeRel",
      "displayName": "MinSizeRel",
      "description": "Release with minimal code size",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "Debug",
      "configurePreset": "Debug",
      "jobs": 8,
      "displayName": "Build Debug",
      "description": "Build Debug configuration"
    },
    {
      "name": "Release",
      "configurePreset": "Release",
      "jobs": 8,
      "displayName": "Build Release",
      "description": "Build Release configuration"
    },
    {
      "name": "RelWithDebInfo",
      "configurePreset": "RelWithDebInfo",
      "jobs": 8,
      "displayName": "Build RelWithDebInfo",
      "description": "Build RelWithDebInfo configuration"
    },
    {
      "name": "MinSizeRel",
      "configurePreset": "MinSizeRel",
      "jobs": 8,
      "displayName": "Build MinSizeRel",
      "description": "Build MinSizeRel configuration"
    }
  ]
}
